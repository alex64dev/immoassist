###> immoassist ###
# Générez un secret : php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=change_me

# Secret JWT pour Mercure (min 256 bits)
MERCURE_JWT_SECRET=change_me_mercure_secret_minimum_32_chars

# Clé API Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-xxxxx

# Modèles Gemini à utiliser. Valeurs possibles (free tier) :
#   gemini-2.5-flash       (recommandé, qualité maximale, parfois en 503)
#   gemini-2.5-flash-lite  (plus léger, quota séparé)
#   gemini-2.0-flash       (génération précédente, très stable)
#
# Le service tente d'abord PRIMARY ; sur quota dépassé / indisponibilité,
# il retente automatiquement avec FALLBACK. Laisser FALLBACK vide pour
# désactiver ce mécanisme de résilience.
GEMINI_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_FALLBACK=gemini-2.5-flash-lite
###< immoassist ###
